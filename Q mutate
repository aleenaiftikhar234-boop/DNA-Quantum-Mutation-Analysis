print(f"Thermal Energy (kbT):     {m['kBT_ev']:.4f} eV (at 310K)")
print("-"*60)
print(f"CORRECTED Tunnel Frequency: {m['freq_hz']:.2e} Hz (~{m['freq_hz']*1e-12:.2f} THz)")
print(f"Tunneling Period (tau):     {m['period_sec']:.2e} seconds")
print(f"Classical Jump Prob:        {m['p_classical']:.2e}")
