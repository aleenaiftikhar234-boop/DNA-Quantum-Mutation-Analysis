FIELD: Quantum Biology / Computational Physics
DESCRIPTION: Solves the Schrödinger Equation for a proton in a DNA 
             hydrogen bond. Corrects the frequency/hbar bug and adds
             thermal decoherence scale metrics.
"""

import numpy as np
import matplotlib.pyplot as plt
from scipy.constants import h, hbar, proton_mass, electron_volt, Boltzmann
from scipy.sparse import diags
from scipy.sparse.linalg import eigsh

class DNAQuantumMutationEngine:
    def __init__(self):
        # Physical Constants
        self.m = proton_mass
        self.T = 310  # Human Body Temperature (Kelvin)

        # Spatial Grid Setup (Angstroms to Meters)
        self.xmin, self.xmax = -1.5e-10, 1.5e-10
        self.N = 2000 
        self.x = np.linspace(self.xmin, self.xmax, self.N)
        self.dx = self.x[1] - self.x[0]

        # Validated Potential Parameters (Ref: Slocombe et al. 2021)
        # self.a in J/m^4 corresponds to ~43.69 eV/Angstrom^4
        self.a = 7e20 
        self.b = 0.35e-10 # 0.35 Angstroms

    def potential(self):
        """Calculates the Quartic Double-Well Potential for G-C base pairs."""
        return self.a * (self.x**2 - self.b**2)**2

    def build_hamiltonian(self):
        """Constructs the Hamiltonian matrix using Finite Difference Method."""
        V = self.potential()
        kinetic_coeff = hbar**2 / (2 * self.m * self.dx**2)

        main_diag = 2 * kinetic_coeff + V
        off_diag = np.ones(self.N - 1) * (-kinetic_coeff)

        H = diags([off_diag, main_diag, off_diag], [-1, 0, 1], format="csr")
        return H

    def solve(self, n_states=3):
        """Finds the lowest energy eigenvalues and wavefunctions."""
        H = self.build_hamiltonian()
        energies, states = eigsh(H, k=n_states, which='SM')
        idx = np.argsort(energies)
        return energies[idx], states[:, idx]

    def run_analysis(self):
        """Computes the final mutation risk metrics with corrected math."""
        energies, states = self.solve()

        # 1. FIXED: Quantum Tunneling Frequency using 'h' instead of 'hbar'
        delta_E = energies[1] - energies[0]
        freq_hz = delta_E / h  # f = delta_E / h
        tunneling_period = 1.0 / freq_hz if freq_hz > 0 else float('inf')

        # 2. Potential Barrier Height Calculations
        barrier_joules = self.a * (self.b**4)
        barrier_ev = barrier_joules / electron_volt
        
        # Convert SI 'a' parameter to eV/A^4 for paper validation
        a_ev_per_ang4 = (self.a / electron_volt) * (1e-10)**4

        # 3. Thermal Energy Scale (k_B * T)
        kBT_joules = Boltzmann * self.T
        kBT_ev = kBT_joules / electron_volt

        # 4. Classical Probability (Boltzmann Jump)
        p_classical = np.exp(-barrier_joules / kBT_joules)

        # Risk Categorization based on corrected True Hz frequency
        if freq_hz < 1e11: status = "Stable (Low Risk)"
        elif freq_hz < 1e12: status = "Metastable (Medium Risk)"
        else: status = "Quantum Instability (High Mutation Risk)"

        metrics = {
            "freq_hz": freq_hz,
            "period_sec": tunneling_period,
            "barrier_ev": barrier_ev,
            "a_manuscript_units": a_ev_per_ang4,
            "kBT_ev": kBT_ev,
            "p_classical": p_classical,
            "status": status,
            "energies_ev": energies / electron_volt,
            "states": states
        }
        return metrics

# --- EXECUTION AND PRESENTATION ---
engine = DNAQuantumMutationEngine()
m = engine.run_analysis()

print("="*60)
